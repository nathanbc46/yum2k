# URL และ KEY จาก Supabase (Settings > API)
# ใช้ Prefix NUXT_PUBLIC_ เพื่อให้เข้าถึงได้ทั้ง Client และ Server
NUXT_PUBLIC_SUPABASE_URL="https://your-project-url.supabase.co"
NUXT_PUBLIC_SUPABASE_KEY="your-anon-key-here"

# Device Auth (สำหรับ Offline-first sync — สร้าง user ใน Supabase Authentication)
NUXT_PUBLIC_SUPABASE_DEVICE_EMAIL="device@your-store.com"
NUXT_PUBLIC_SUPABASE_DEVICE_PASSWORD="your-device-password"

# LINE Messaging API — แจ้งเตือนออร์เดอร์, สต็อก, สรุปรายวัน
# Channel Secret: LINE Developers > Basic settings
NUXT_LINE_CHANNEL_SECRET="your-line-channel-secret"
# Channel Access Token: LINE Developers > Messaging API > Channel access token (long-lived)
NUXT_LINE_CHANNEL_ACCESS_TOKEN="your-channel-access-token"

# Supabase Service Role Key (server-side เท่านั้น — ไม่ expose ไปที่ client)
# ดูได้จาก Supabase Dashboard > Settings > API > service_role key
NUXT_SUPABASE_SERVICE_KEY="your-service-role-key"

# Default AI API Keys — ใช้เป็น fallback เมื่อไม่ได้กรอก key ในหน้า admin/settings
# หากกรอก key ในหน้า settings จะใช้ key นั้นแทน
NUXT_PUBLIC_DEFAULT_GEMINI_KEY=""
NUXT_PUBLIC_DEFAULT_GROQ_KEY=""
NUXT_PUBLIC_DEFAULT_OPENROUTER_KEY=""
